# dependencies
node_modules/

# bun
.bun/

# build / coverage
coverage/
dist/

# downloaded native frpc binary (fetched by scripts/postinstall.ts)
bin/

# runtime state (sqlite registries, generated client configs) — never commit
*.db
*.db-shm
*.db-wal

# secrets — passed via env / mounted, never committed
.env
.env.*
!.env.example
certs/
jwt-private*
# TLS private keys (CA + frps server). The CA *cert* (frps-ca.crt) is public and committed.
*.key

# logs
*.log

# editor / os
.DS_Store
.idea/
.vscode/
