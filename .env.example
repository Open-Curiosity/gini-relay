# Copy to .env (gitignored) and fill in, or inject from CI secrets.

# Shared token every frpc client presents to frps (coarse gate).
FRP_AUTH_TOKEN=

# Google OAuth client. Both set => live Google login. Empty => stub mode, which
# requires GINI_ALLOW_STUB=1 or the brain refuses to start (no open auth in prod).
# Register the loopback redirect URIs http://127.0.0.1:8765/cb .. :8767/cb on the client.
GINI_GOOGLE_CLIENT_ID=
GINI_GOOGLE_CLIENT_SECRET=

# Dev only: 1 permits stub (no-Google) auth. Never set in prod.
GINI_ALLOW_STUB=
